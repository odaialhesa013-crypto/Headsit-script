local function getPlayer(name)
    if not name or name == "" then return nil end
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= plr then
            if p.Name:lower():find(name,1,true) or p.DisplayName:lower():find(name,1,true) then
                return p
            end
        end
    end
end

local function updatePlayerList()
    for _, c in pairs(PlayerList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local count = 0
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= plr then
            count += 1
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-6,0,30)
            btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
            btn.Text = p.DisplayName.." (@"..p.Name..")"
            btn.TextColor3 = Color3.fromRGB(200,200,200)
            btn.TextSize = 12
            btn.Font = Enum.Font.Gotham
            btn.Parent = PlayerList
            Instance.new("UICorner",btn).CornerRadius = UDim.new(0,6)
            btn.MouseButton1Click:Connect(function()
                SearchBox.Text = p.Name
                SearchBox:ReleaseFocus()
            end)
        end
    end
    PlayerList.CanvasSize = UDim2.new(0,0,0,count*33)
end

local function makeInvisible()
    local char = plr.Character
    if not char then return end
    State.OriginalProps = {}
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
            State.OriginalProps[p] = {Transparency = p.Transparency, LocalTransparencyModifier = p.LocalTransparencyModifier}
            p.Transparency = 1
            p.LocalTransparencyModifier = 1
        elseif p:IsA("Decal") or p:IsA("SpecialMesh") or p:IsA("SurfaceAppearance") then
            State.OriginalProps[p] = {Transparency = p.Transparency}
            p.Transparency = 1
        end
    end
    for _, acc in pairs(char:GetChildren()) do
        if acc:IsA("Accessory") then
            local handle = acc:FindFirstChild("Handle")
            if handle then
                State.OriginalProps[handle] = {Transparency = handle.Transparency}
                handle.Transparency = 1
            end
        end
    end
    State.Invisible = true
    InvisBtn.Text = "👁 إخفاء الجسم: ON"
    InvisBtn.BackgroundColor3 = Color3.fromRGB(255,140,0)
end

local function makeVisible()
    local char = plr.Character
    if not char then return end
    for p, props in pairs(State.OriginalProps) do
        if p and p.Parent then
            if props.Transparency ~= nil then p.Transparency = props.Transparency end
            if props.LocalTransparencyModifier ~= nil then p.LocalTransparencyModifier = props.LocalTransparencyModifier end
        end
    end
    State.OriginalProps = {}
    State.Invisible = false
    InvisBtn.Text = "👁 إخفاء الجسم: OFF"
    InvisBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)
end

InvisBtn.MouseButton1Click:Connect(function()
    if State.Invisible then makeVisible() else makeInvisible() end
end)

function stopGhost()
    State.Running = false; State.Target = nil
    State.LastPos = nil; State.LastTime = nil; State.Velocity = Vector3.zero
    if State.Connection then State.Connection:Disconnect(); State.Connection = nil end
    if State.Invisible then makeVisible() end
    local char = plr.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false; hum.AutoRotate = true; hum.WalkSpeed = 16; hum.JumpPower = 50 end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false; hrp.AssemblyLinearVelocity = Vector3.zero; hrp.AssemblyAngularVelocity = Vector3.zero end
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = true; p.Massless = false; p.Anchored = false end
        end
    end
    StatusLabel.Text = "🔴 غير متصل"; StatusLabel.TextColor3 = Color3.fromRGB(255,80,80)
    HeadsitBtn.BackgroundColor3 = Color3.fromRGB(0,200,100)
end

local function startGhost(insideMode)
    if State.Running then stopGhost(); task.wait(0.1) end
    local target = getPlayer(SearchBox.Text)
    if not target then StatusLabel.Text = "❌ لم يتم العثور على اللاعب"; StatusLabel.TextColor3 = Color3.fromRGB(255,80,80); return end
    local myChar = plr.Character
    if not myChar then return end
    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return end
    State.Mode = insideMode and "inside" or "head"; State.Target = target; State.Running = true
    State.LastPos = nil; State.LastTime = nil; State.Velocity = Vector3.zero
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if myHum then myHum.PlatformStand = true; myHum.AutoRotate = false; myHum.WalkSpeed = 0; myHum.JumpPower = 0 end
    for _, p in pairs(myChar:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false; p.Massless = true end
    end
    myHrp.AssemblyLinearVelocity = Vector3.zero; myHrp.AssemblyAngularVelocity = Vector3.zero
    local offset = insideMode and CONFIG.InsideOffset or CONFIG.HeadOffset
    local modeText = insideMode and "داخل الجسم" or "فوق الرأس"
    StatusLabel.Text = "🟢 ملصوق: "..target.DisplayName.." ("..modeText..")"
    StatusLabel.TextColor3 = Color3.fromRGB(0,255,136)
    HeadsitBtn.BackgroundColor3 = Color3.fromRGB(255,160,0)
    State.Connection = RunService.PreSimulation:Connect(function(dt)
        if not State.Running then return end
        local tc = State.Target and State.Target.Character
        if not tc then StatusLabel.Text = "🟡 انتظر respawn..."; return end
        local tHrp = tc:FindFirstChild("HumanoidRootPart")
        local mChar = plr.Character
        local mHrp = mChar and mChar:FindFirstChild("HumanoidRootPart")
        if not tHrp or not mHrp then return end
        local currentPos = tHrp.Position
        local currentTime = tick()
        if State.LastPos and State.LastTime then
            local timeDiff = currentTime - State.LastTime
            if timeDiff > 0 then
                local rawVelocity = (currentPos - State.LastPos) / timeDiff
                State.Velocity = State.Velocity:Lerp(rawVelocity, 0.6)
            end
        end
        State.LastPos = currentPos; State.LastTime = currentTime
        local predictedPos = currentPos + (State.Velocity * dt * CONFIG.PredictFactor)
        local predictedCFrame = CFrame.new(predictedPos) * (tHrp.CFrame - tHrp.CFrame.Position)
        mHrp.AssemblyLinearVelocity = Vector3.zero; mHrp.AssemblyAngularVelocity = Vector3.zero
        mHrp.CFrame = predictedCFrame * offset
        local mHum = mChar:FindFirstChildOfClass("Humanoid")
        if mHum then mHum.PlatformStand = true; mHum.WalkSpeed = 0; mHum.JumpPower = 0 end
        StatusLabel.Text = "🟢 ملصوق: "..State.Target.DisplayName
        StatusLabel.TextColor3 = Color3.fromRGB(0,255,136)
    end)
end

