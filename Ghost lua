UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then ToggleBtn.MouseButton1Click:Fire()
    elseif input.KeyCode == Enum.KeyCode.End then stopGhost()
    elseif input.KeyCode == Enum.KeyCode.F then
        if State.Invisible then makeVisible() else makeInvisible() end
    end
end)

